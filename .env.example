# Local dev (docker compose up db)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

PORT=3001
CORS_ORIGIN=http://localhost:3000

JWT_SECRET=
JWT_EXPIRES_IN=1d

ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Vercel: configure the same variables in Project Settings → Environment Variables.
# Use a hosted Postgres (Neon, Supabase, Vercel Postgres, etc.) — not docker-compose in production.
# Prefer a pooled connection string for serverless (e.g. Neon ?sslmode=require).
